{
  "name": "viz-runner",
  "displayName": "viz-runner",
  "description": "viz-runner is a VS Code extension for compiling and visualizing VizLang, a custom language designed to reveal how a compiler works (usually a black box). It uses a Docker-based compiler to show step-by-step stages like tokens, AST, IR, optimization, and assembly output.",
  "publisher": "RohithVenkatMutyala",
  "version": "2.1.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RohitVenkatMutyala/extension"
  },
  "icon": "i.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "viz.start",
        "title": "Start Viz Container"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.70.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
