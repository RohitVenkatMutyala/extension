{
  "name": "viz-runner",
  "displayName": "viz-runner",
 "description": "Viz Runner is a VS Code extension for compiling and visualizing VizLang programs. It runs a Docker-based compiler and provides step-by-step insights into the compilation pipeline, including tokens, AST, IR, optimization, and assembly output.",
  "publisher": "RohithVenkatMutyala",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.110.0"
  },
  
  "categories": [
    "Other"
  ],
  "icon":"icon.ico",
  "activationEvents": [
    "onStartupFinished"
],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
       "command": "viz.start",
      "title": "Start Viz Container"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
